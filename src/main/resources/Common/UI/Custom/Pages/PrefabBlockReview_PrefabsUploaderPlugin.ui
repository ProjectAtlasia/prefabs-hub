$C = "../Common.ui";

// UI "Revisao de Blocos" (admin) — PrefabsUploader. Autor: astahjmo (Astaroth).
// Lista os tipos de bloco/fluido da prefab com contagem; o admin clica numa linha pra permitir/
// bloquear, e "Confirmar" salva so com os blocos permitidos. 20 linhas paginadas (#Row0..#Row19).

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 760, Height: 720);

  #Title {
    Group { $C.@Title { @Text = %server.prefabsuploader.blockreview.title; } }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Horizontal: 16, Bottom: 16, Top: 4);

    Label #PrefabName { Anchor: (Height: 22, Bottom: 2);
      Style: (FontSize: 15, RenderBold: true, TextColor: #88ccff, HorizontalAlignment: Center); }
    Label { Anchor: (Height: 18, Bottom: 6);
      Style: (FontSize: 12, TextColor: #94a7bb, HorizontalAlignment: Center);
      Text: %server.prefabsuploader.blockreview.hint; }
    Label #PageInfo { Anchor: (Height: 18, Bottom: 6);
      Style: (FontSize: 13, RenderBold: true, TextColor: #88ccff); }

    Group #BlockList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Horizontal: 4);

      Button #Row0 { Visible: false; Anchor: (Top: 2, Height: 32); Style: (...$C.@SecondaryButtonStyle);
        Group { LayoutMode: Center; Padding: (Horizontal: 12);
          Label #RowState0 { Anchor: (Width: 40); Style: (FontSize: 15, RenderBold: true); }
          Label #RowName0  { FlexWeight: 1; Style: (FontSize: 14); }
          Label #RowCount0 { Anchor: (Width: 110); Style: (FontSize: 13, HorizontalAlignment: End); }
        }
      }
      Button #Row1 { Visible: false; Anchor: (Top: 2, Height: 32); Style: (...$C.@SecondaryButtonStyle);
        Group { LayoutMode: Center; Padding: (Horizontal: 12);
          Label #RowState1 { Anchor: (Width: 40); Style: (FontSize: 15, RenderBold: true); }
          Label #RowName1  { FlexWeight: 1; Style: (FontSize: 14); }
          Label #RowCount1 { Anchor: (Width: 110); Style: (FontSize: 13, HorizontalAlignment: End); }
        }
      }
      Button #Row2 { Visible: false; Anchor: (Top: 2, Height: 32); Style: (...$C.@SecondaryButtonStyle);
        Group { LayoutMode: Center; Padding: (Horizontal: 12);
          Label #RowState2 { Anchor: (Width: 40); Style: (FontSize: 15, RenderBold: true); }
          Label #RowName2  { FlexWeight: 1; Style: (FontSize: 14); }
          Label #RowCount2 { Anchor: (Width: 110); Style: (FontSize: 13, HorizontalAlignment: End); }
        }
      }
      Button #Row3 { Visible: false; Anchor: (Top: 2, Height: 32); Style: (...$C.@SecondaryButtonStyle);
