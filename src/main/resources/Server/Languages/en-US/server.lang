# ---- /prefabs-uploader link (player account link) ----
prefabsuploader.command.link.description = Link your Hytale account to Discord
prefabsuploader.link.notplayer = Only players can use /prefabs-uploader link.
prefabsuploader.link.needsLink = Link your account. On Discord, type:
prefabsuploader.link.code = /link {code}
prefabsuploader.link.invitePrompt = Not in the server? Join:
prefabsuploader.link.inviteButton = [ Discord ]
prefabsuploader.link.waiting = Waiting for you to link on Discord (3 min)…
prefabsuploader.link.linked = Account linked! Discord: {discord}
prefabsuploader.link.expired = Timed out. Run /prefabs-uploader import again to resend.
prefabsuploader.link.alreadyLinked = Your account is already linked. Use /prefabs-uploader import.
prefabsuploader.link.hubError = Could not reach the hub. Make sure the Discord bot is online.

